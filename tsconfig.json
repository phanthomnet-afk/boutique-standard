{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@tbs/schema": ["./packages/schema/index.ts"],
      "@tbs/checklist": ["./packages/checklist/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
