{
  "name": "boutique-standard",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "pdf": "npm run generate --workspace=packages/pdf-engine",
    "typecheck": "tsc --noEmit",
    "checkpoint": "bash scripts/checkpoint.sh",
    "restore": "bash scripts/restore.sh",
    "snapshots": "git tag -l 'checkpoint/*' | sort -r",
    "seed:report": "npx tsx apps/web/scripts/seedReport.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "allowScripts": {
    "@prisma/client@5.22.0": true,
    "@prisma/engines@5.22.0": true,
    "prisma@5.22.0": true
  }
}
